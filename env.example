# ─────────────────────────────────────────────────────────────────────────────
# ATLAS OUTREACH — ENVIRONMENT VARIABLES
# Copy this file to .env and fill in your values.
# Never commit .env to git.
# ─────────────────────────────────────────────────────────────────────────────

# Gemini API key (for email generation)
# Get yours at: https://aistudio.google.com/
GEMINI_API_KEY=AIzaSy...

# Resend API key (for sending emails)
# Sign up free at: https://resend.com — free tier: 3,000 emails/month
# Docs: https://resend.com/docs/send-with-nodejs
RESEND_API_KEY=re_...

# The "From" address — must be a verified domain or email in Resend
# Resend requires domain verification for custom domains.
# For quick testing, use the Resend sandbox: onboarding@resend.dev
SENDER_FROM=you@yourdomain.com

# Your name as it appears in the "From" field
SENDER_NAME=Your Name

# Reply-to address (usually same as SENDER_FROM)
REPLY_TO=you@yourdomain.com
