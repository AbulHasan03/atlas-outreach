# ─────────────────────────────────────────────────────────────────────────────
# ATLAS OUTREACH — ENVIRONMENT VARIABLES
# Rename this file to .env and fill in your values.
# Never commit .env to git.
# ─────────────────────────────────────────────────────────────────────────────

# ── AI (email generation) ─────────────────────────────────────────────────────
# Primary: Claude — get key at https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...

# Fallback: Gemini — get key at https://aistudio.google.com (free, no credit card)
GEMINI_API_KEY=AIza...

# ── EMAIL SENDING ─────────────────────────────────────────────────────────────
# Sign up free at: https://resend.com (3,000 emails/month free)
RESEND_API_KEY=re_...
SENDER_FROM=you@yourdomain.com
SENDER_NAME=Your Name
SENDER_TITLE=Your Title
SENDER_PHONE=+1 (555) 000-0000
REPLY_TO=you@yourdomain.com

# Test mode — all emails redirect to this address instead of real prospects
# Remove or leave blank to send to real prospects
TEST_EMAIL_OVERRIDE=your@email.com

# ── DATABASE ──────────────────────────────────────────────────────────────────
# Supabase — find both in: Dashboard → Settings → API Keys
# Use the Secret key (sb_secret_...) not the Publishable key
SUPABASE_URL=https://yourproject.supabase.co
SUPABASE_SERVICE_KEY=sb_secret_...

# ── SENDING BEHAVIOUR ────────────────────────────────────────────────────────
# Max emails to send per cron run (safety cap — remove to send all due)
MAX_SENDS=2

# Time the cron runs — used to display "Auto-send: May 11 at 8:00 AM" in UI
# Must match your crontab schedule (24hr format)
CRON_SEND_TIME=08:00

# To start the UI, run:
# node run.js --ui